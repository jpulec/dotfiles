#!/usr/bin/env fish
# Helper script for wt-workspace: creates worktree with loading animation
# Usage: wt-workspace-create <worktree-dir> <worktree-name> <base-branch>

set WORKTREE_DIR $argv[1]
set worktree_name $argv[2]
set base_branch $argv[3]
set worktree_path "$WORKTREE_DIR/$worktree_name"
set branch_name "_$worktree_name"

# Check if branch already exists
set branch_exists false
if git -C "$WORKTREE_DIR" show-ref --verify --quiet "refs/heads/$branch_name"
    set branch_exists true
end

# Start git worktree add in background
set tmpfile (mktemp)
if test "$branch_exists" = true
    # Branch exists, just add worktree using existing branch
    fish -c "git -C '$WORKTREE_DIR' worktree add '$worktree_path' '$branch_name' &>$tmpfile; echo \$status > $tmpfile.status" &
else
    # Create new branch
    fish -c "git -C '$WORKTREE_DIR' worktree add -b '$branch_name' '$worktree_path' '$base_branch' &>$tmpfile; echo \$status > $tmpfile.status" &
end
set git_pid $last_pid

# Spinner animation
set spinner 'таЛ' 'таЩ' 'та╣' 'та╕' 'та╝' 'та┤' 'таж' 'таз' 'таЗ' 'таП'
set i 1

printf "\n"
while kill -0 $git_pid 2>/dev/null
    if test "$branch_exists" = true
        printf "\r  %s Creating worktree '\e[1;36m%s\e[0m' using existing branch \e[1;33m%s\e[0m..." $spinner[$i] $worktree_name $branch_name
    else
        printf "\r  %s Creating worktree '\e[1;36m%s\e[0m' from \e[1;33m%s\e[0m..." $spinner[$i] $worktree_name $base_branch
    end
    set i (math "($i % 10) + 1")
    sleep 0.08
end

# Wait for process and get status
wait $git_pid
set git_status (cat $tmpfile.status 2>/dev/null; or echo 1)

printf "\r\e[K"  # Clear the line

if test "$git_status" -eq 0
    printf "  \e[1;32mтЬУ\e[0m Worktree '\e[1;36m%s\e[0m' created!\n" $worktree_name
    rm -f $tmpfile $tmpfile.status

    # Create .envrc file
    printf "source_up\n\nexport COMPOSE_PROJECT_NAME=%s\n" $worktree_name > "$worktree_path/.envrc"
    printf "  \e[1;32mтЬУ\e[0m Created .envrc\n"

    # Allow direnv
    direnv allow "$worktree_path"
    printf "  \e[1;32mтЬУ\e[0m Ran direnv allow\n"

    # Setup Doppler for secrets
    if command -q doppler
        doppler setup --no-interactive -c "$worktree_path" >/dev/null 2>&1
        and printf "  \e[1;32mтЬУ\e[0m Ran doppler setup\n"
        or printf "  \e[1;33mтЪа\e[0m Doppler setup skipped (no config found)\n"
    end

    printf "\n"
    cd $worktree_path
    exec fish
else
    printf "  \e[1;31mтЬЧ\e[0m Failed to create worktree\n\n"
    printf "\e[2m"  # Dim
    cat $tmpfile
    printf "\e[0m\n"
    rm -f $tmpfile $tmpfile.status
    read -P "Press enter to close..."
end
