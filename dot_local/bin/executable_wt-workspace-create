#!/usr/bin/env fish
# Helper for wt-workspace: creates a worktree with a loading animation, then
# runs per-repo setup (envrc, compose overrides, doppler, install).
#
# Usage: wt-workspace-create <repo-name> <worktree-name> <base-branch>
# repo-name resolves to ~/.config/wt-workspace/repos/<repo-name>.fish

set --local CONFIG_DIR "$HOME/.config/wt-workspace/repos"

set --local repo_name $argv[1]
set --local worktree_name $argv[2]
set --local base_branch $argv[3]

if test -z "$repo_name" -o -z "$worktree_name" -o -z "$base_branch"
    printf "Usage: wt-workspace-create <repo-name> <worktree-name> <base-branch>\n"
    read -P "Press enter to close..."
    exit 1
end

set --local config_file "$CONFIG_DIR/$repo_name.fish"
if not test -f "$config_file"
    printf "Config not found: %s\n" "$config_file"
    read -P "Press enter to close..."
    exit 1
end
source "$config_file"

set --local worktree_path "$WT_REPO_DIR/$worktree_name"
set --local branch_name "$WT_BRANCH_PREFIX$worktree_name"

# ---- create the worktree (with spinner) ------------------------------------

set --local branch_exists false
if git -C "$WT_REPO_DIR" show-ref --verify --quiet "refs/heads/$branch_name"
    set branch_exists true
end

set --local tmpfile (mktemp)
if test "$branch_exists" = true
    fish -c "git -C '$WT_REPO_DIR' worktree add '$worktree_path' '$branch_name' &>$tmpfile; echo \$status > $tmpfile.status" &
else
    fish -c "git -C '$WT_REPO_DIR' worktree add -b '$branch_name' '$worktree_path' '$base_branch' &>$tmpfile; echo \$status > $tmpfile.status" &
end
set --local git_pid $last_pid

set --local spinner '⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏'
set --local i 1

printf "\n"
while kill -0 $git_pid 2>/dev/null
    if test "$branch_exists" = true
        printf "\r  %s Creating worktree '\e[1;36m%s\e[0m' using existing branch \e[1;33m%s\e[0m..." $spinner[$i] $worktree_name $branch_name
    else
        printf "\r  %s Creating worktree '\e[1;36m%s\e[0m' from \e[1;33m%s\e[0m..." $spinner[$i] $worktree_name $base_branch
    end
    set i (math "($i % 10) + 1")
    sleep 0.08
end

wait $git_pid
set --local git_status (cat $tmpfile.status 2>/dev/null; or echo 1)

printf "\r\e[K"

if test "$git_status" -ne 0
    printf "  \e[1;31m✗\e[0m Failed to create worktree\n\n"
    printf "\e[2m"
    cat $tmpfile
    printf "\e[0m\n"
    rm -f $tmpfile $tmpfile.status
    read -P "Press enter to close..."
    exit 1
end

printf "  \e[1;32m✓\e[0m Worktree '\e[1;36m%s\e[0m' created!\n" $worktree_name
rm -f $tmpfile $tmpfile.status

# ---- .envrc ----------------------------------------------------------------

# Build .envrc. WT_EXTRA_ENVRC may reference $worktree_name, so eval it.
set --local extra_envrc ""
if test -n "$WT_EXTRA_ENVRC"
    set extra_envrc (eval "echo \"$WT_EXTRA_ENVRC\"")
end

printf "source_up\n\n%s\n" "$extra_envrc" > "$worktree_path/.envrc"
printf "  \e[1;32m✓\e[0m Created .envrc\n"

direnv allow "$worktree_path"
printf "  \e[1;32m✓\e[0m Ran direnv allow\n"

# ---- optional docker-compose override symlink ------------------------------

if test -n "$WT_COMPOSE_OVERRIDE_SRC" -a -n "$WT_COMPOSE_OVERRIDE_DEST"
    if test -f "$WT_COMPOSE_OVERRIDE_SRC"
        set --local dest "$worktree_path/$WT_COMPOSE_OVERRIDE_DEST"
        mkdir -p (dirname "$dest")
        ln -sf "$WT_COMPOSE_OVERRIDE_SRC" "$dest"
        printf "  \e[1;32m✓\e[0m Linked docker-compose local overrides\n"
    end
end

# ---- doppler ---------------------------------------------------------------

if command -q doppler
    switch "$WT_DOPPLER_MODE"
        case yaml
            # When a doppler.yaml is present in the worktree, a single
            # `doppler setup --no-interactive` configures every path it lists.
            if doppler setup --no-interactive --scope "$worktree_path" >/dev/null 2>&1
                printf "  \e[1;32m✓\e[0m Ran doppler setup\n"
            else
                printf "  \e[1;33m⚠\e[0m doppler setup failed (run manually)\n"
            end
        case apps
            set --local doppler_ok true
            set --local config "$WT_DOPPLER_CONFIG"
            if test -z "$config"
                set config "dev_personal"
            end
            for pair in $WT_DOPPLER_APPS
                set --local app_dir (string split ':' $pair)[1]
                set --local project (string split ':' $pair)[2]
                if not doppler setup --no-interactive --project $project --config $config --scope "$worktree_path/$app_dir" >/dev/null 2>&1
                    printf "  \e[1;33m⚠\e[0m Doppler setup failed for %s\n" $app_dir
                    set doppler_ok false
                end
            end
            if test "$doppler_ok" = true
                printf "  \e[1;32m✓\e[0m Ran doppler setup\n"
            end
        case none ''
            # skip
        case '*'
            printf "  \e[1;33m⚠\e[0m Unknown WT_DOPPLER_MODE '%s', skipping\n" "$WT_DOPPLER_MODE"
    end
end

# ---- install (detached, runs in the background) ----------------------------
#
# The install (typically `yarn install` + heavy postinstall codegen/build:types)
# is the slowest step by far. We detach it so the new shell drops into the
# worktree immediately. A desktop notification fires when it finishes.

if test -n "$WT_INSTALL_CMD"
    set --local log_dir "$HOME/.cache/wt-workspace"
    mkdir -p "$log_dir"
    set --local log_file "$log_dir/$repo_name-$worktree_name.log"

    # Escape single quotes in the install command for safe embedding in the
    # single-quoted fish -c payload below.
    set --local install_cmd_escaped (string replace --all "'" "'\\''" -- "$WT_INSTALL_CMD")

    # Wrap the install in a fish script that:
    #   1. cd's into the worktree
    #   2. runs the install via `direnv exec` so the per-worktree env loads
    #   3. fires notify-send with success/failure when done
    set --local payload "cd '$worktree_path'; \
        printf '[%s] starting: %s\n' (date '+%H:%M:%S') '$install_cmd_escaped'; \
        if direnv exec '$worktree_path' fish -c '$install_cmd_escaped'; \
            printf '[%s] done\n' (date '+%H:%M:%S'); \
            notify-send --app-name=wt-workspace --icon=dialog-information \
                'wt-workspace: $worktree_name ready' \
                'Install finished in $worktree_name ($repo_name)'; \
        else; \
            printf '[%s] FAILED\n' (date '+%H:%M:%S'); \
            notify-send --app-name=wt-workspace --urgency=critical --icon=dialog-error \
                'wt-workspace: $worktree_name install failed' \
                'See $log_file'; \
        end"

    # Detach: nohup + & + disown so the job survives this terminal closing.
    nohup fish -c "$payload" >"$log_file" 2>&1 &
    disown

    printf "  \e[1;32m✓\e[0m Started \e[1m%s\e[0m in background\n" "$WT_INSTALL_CMD"
    printf "      log: \e[2m%s\e[0m\n" "$log_file"
    printf "      you'll get a notification when it finishes\n"
end

printf "\n"
cd $worktree_path
exec fish
