root = true

[*]
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 80

[Makefile]
indent_style = tab

[*.go]
indent_style = tab

[*.{js,jsx,mjs,cjs,ts,tsx,vue,svelte}]
indent_size = 2

[*.{json,jsonc,yaml,yml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{html,htm,css,scss,sass,less}]
indent_size = 2

[*.{rs,kt,java}]
indent_size = 4
