{
  "$schema": "https://opencode.ai/config.json",
  "layout": "stretch",
  "snapshot": false,
  "plugin": ["@mohak34/opencode-notifier@0.1.10"],
  "formatter": {
    "biome": {
      "disabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "ast-grep*": "allow",
      "awk*": "allow",
      "basename*": "allow",
      "bun --version": "allow",
      "bun *": "allow",
      "cat*": "allow",
      "chmod *": "allow",
      "date *": "allow",
      "diff*": "allow",
      "docker build*": "allow",
      "doppler run --project cloudwatch-readonly*": "allow",
      "du*": "allow",
      "echo*": "allow",
      "fastmod*": "allow",
      "file*": "allow",
      "find*": "ask",
      "gh issue view*": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh pr view*": "allow",
      "gh release view*": "allow",
      "gh repo view*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh search*": "allow",
      "git add*": "deny",
      "git blame*": "allow",
      "git branch --show-current": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git merge-base*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "git worktree list": "allow",
      "grep*": "allow",
      "head*": "allow",
      "jq*": "allow",
      "ls*": "allow",
      "mkdir*": "allow",
      "node --version": "allow",
      "npm --version": "allow",
      "npm test*": "allow",
      "npm tsgo*": "allow",
      "npm turbo*": "allow",
      "npm view*": "allow",
      "npx oxlint*": "allow",
      "pwd*": "allow",
      "rg*": "allow",
      "sed*": "allow",
      "sg *": "allow",
      "sort*": "allow",
      "sudo*": "deny",
      "tail*": "allow",
      "time*": "allow",
      "tsgo*": "allow",
      "wc*": "allow",
      "yarn *": "allow"
    }
  }
}
